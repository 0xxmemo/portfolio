---
import { showcaseSections } from "../../data/portfolio";
import AboutSection from "./AboutSection.astro";
import ExperienceSection from "./ExperienceSection.astro";
import ProjectsSection from "./ProjectsSection.astro";
import TechStackSection from "./TechStackSection.astro";
import AwardsSection from "./AwardsSection.astro";
import LinksSection from "./LinksSection.astro";
import ContactSection from "./ContactSection.astro";

const n = showcaseSections.length;
---

<div class="fixed left-6 top-1/2 -translate-y-1/2 z-50 hidden lg:flex flex-col gap-3">
  {
    showcaseSections.map((s, i) => (
      <a href={`#${s.id}`} class="group flex items-center gap-3">
        <div
          data-showcase-nav
          class="w-2 h-2 rounded-full transition-all duration-300"
          style={{
            background: i === 0 ? s.color : "rgba(255,255,255,0.15)",
            boxShadow: i === 0 ? `0 0 8px ${s.color}` : "none",
            transform: i === 0 ? "scale(1.5)" : "scale(1)",
          }}
        />
        <span
          data-nav-label
          class="text-[10px] font-mono uppercase tracking-wider opacity-0 group-hover:opacity-100 transition-opacity duration-200"
          style={{ color: i === 0 ? s.color : "rgba(255,255,255,0.3)" }}
        >
          {s.id}
        </span>
      </a>
    ))
  }
</div>

<div id="showcase-scroll-container" style={{ height: `${n * 100}vh` }} class="relative">
  {
    showcaseSections.map((s, i) => (
      <div id={s.id} class="absolute" style={{ top: `${(i / n) * 100}%` }} />
    ))
  }

  <div class="sticky top-0 min-h-screen flex items-center overflow-hidden py-8 sm:py-12 md:py-16">
    <div
      id="showcase-gradient"
      class="absolute inset-0 transition-opacity duration-700 pointer-events-none"
      style="background: radial-gradient(ellipse at 70% 50%, rgba(16,185,129,0.08) 0%, rgba(16,185,129,0.03) 40%, transparent 70%)"
    />

    <div class="w-full max-w-4xl mx-auto px-5 sm:px-8 lg:px-12 relative min-h-[70vh] flex items-center">
      {
        showcaseSections.map((s, i) => (
          <div
            data-showcase-panel={s.id}
            class="showcase-panel absolute inset-x-0 top-1/2 -translate-y-1/2 px-5 sm:px-8 lg:px-12"
            style={{
              opacity: i === 0 ? 1 : 0,
              pointerEvents: i === 0 ? "auto" : "none",
            }}
          >
            {s.id === "about" && <AboutSection />}
            {s.id === "experience" && <ExperienceSection />}
            {s.id === "projects" && <ProjectsSection />}
            {s.id === "tech" && <TechStackSection />}
            {s.id === "awards" && <AwardsSection />}
            {s.id === "links" && <LinksSection />}
            {s.id === "contact" && <ContactSection />}
          </div>
        ))
      }
    </div>
  </div>
</div>
