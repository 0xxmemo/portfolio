#!/usr/bin/env bun
// Live-preview server for resume.html
// Serves the file at / and pushes a "reload" SSE event whenever the file
// changes on disk. Open the printed URL in a browser and edit resume.html;
// the page reloads automatically.

import { watch } from "node:fs";
import { resolve, dirname } from "node:path";
import { fileURLToPath } from "node:url";

const ROOT = resolve(dirname(fileURLToPath(import.meta.url)), "..");
const RESUME = resolve(ROOT, "resume.html");
const PORT = Number(process.env.PORT ?? 4173);

const clients = new Set();
const enc = new TextEncoder();

function broadcast(event) {
  const payload = enc.encode(`data: ${event}\n\n`);
  for (const c of clients) {
    try { c.enqueue(payload); } catch { clients.delete(c); }
  }
}

let debounce = null;
watch(RESUME, () => {
  if (debounce) clearTimeout(debounce);
  debounce = setTimeout(() => broadcast("reload"), 80);
});

const server = Bun.serve({
  port: PORT,
  async fetch(req) {
    const url = new URL(req.url);

    if (url.pathname === "/__reload") {
      const stream = new ReadableStream({
        start(controller) {
          clients.add(controller);
          controller.enqueue(enc.encode(": connected\n\n"));
        },
        cancel() {
          // controller is gone; entry will be evicted on next broadcast
        },
      });
      return new Response(stream, {
        headers: {
          "content-type": "text/event-stream",
          "cache-control": "no-cache, no-transform",
          "connection": "keep-alive",
        },
      });
    }

    if (url.pathname === "/" || url.pathname === "/resume.html") {
      const file = Bun.file(RESUME);
      if (!(await file.exists())) {
        return new Response("resume.html not found", { status: 404 });
      }
      return new Response(file, {
        headers: { "content-type": "text/html; charset=utf-8", "cache-control": "no-store" },
      });
    }

    return new Response("not found", { status: 404 });
  },
});

console.log(`resume preview → http://localhost:${server.port}`);
console.log(`watching        → ${RESUME}`);
